{
  "name": "cyclonedx-assessors-studio-backend",
  "version": "0.1.0",
  "description": "CycloneDX Assessors Studio Backend",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "storage:migrate": "tsx src/storage/migrate-storage.ts",
    "db:reset": "rm -rf data/pglite && echo 'Database reset. It will be recreated on next server start.'",
    "test": "vitest"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.8",
    "@types/busboy": "^1.5.4",
    "@types/pdfkit": "^0.17.5",
    "argon2": "^0.44.0",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jose": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.28.14",
    "kysely-pglite": "^0.6.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "kysely-pglite": {
      "kysely-codegen": {
        "kysely": "$kysely"
      }
    }
  }
}
