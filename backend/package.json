{
  "name": "cyclonedx-assessors-studio-backend",
  "version": "0.5.0",
  "description": "CycloneDX Assessors Studio Backend",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "db:reset": "rm -rf data/pglite && echo 'Database reset. It will be recreated on next server start.'",
    "test": "vitest",
    "test:run": "vitest run; EXIT_CODE=$?; rm -rf data ../data; exit $EXIT_CODE",
    "posttest": "rm -rf data ../data",
    "encrypt-secrets": "tsx src/scripts/encrypt-secrets.ts",
    "rotate-encryption-key": "tsx src/scripts/rotate-encryption-key.ts",
    "rekey-master": "tsx src/scripts/rekey-master.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1029.0",
    "@electric-sql/pglite": "0.4.4",
    "@types/busboy": "1.5.4",
    "@types/pdfkit": "0.17.5",
    "argon2": "0.44.0",
    "busboy": "1.6.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "jose": "6.2.2",
    "jsonwebtoken": "9.0.3",
    "kysely": "0.28.15",
    "kysely-pglite": "0.6.1",
    "nodemailer": "8.0.5",
    "prom-client": "15.1.3",
    "pdfkit": "0.18.0",
    "pg": "8.20.0",
    "uuid": "13.0.0",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.5.2",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@types/uuid": "11.0.0",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "@vitest/coverage-v8": "4.1.4"
  },
  "overrides": {
    "kysely-pglite": {
      "kysely-codegen": {
        "kysely": "$kysely"
      }
    }
  }
}
