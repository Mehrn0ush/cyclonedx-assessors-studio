# Database
DATABASE_PROVIDER=pglite
DATABASE_URL=postgresql://localhost:5432/assessors_studio
PGLITE_DATA_DIR=./data/pglite

# JWT
# Optional. When unset the backend generates a signing secret on first
# run and persists it in the app_config table. Set an explicit value
# (>= 32 chars) for multi-replica deployments or to manage the key
# externally. Changing the value invalidates all active sessions.
# JWT_SECRET=
JWT_EXPIRY=24h

# Server
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# Initial administrator account
# The first admin is created through the in-browser setup wizard at /setup
# on first visit. No admin credentials are configured via environment.

# Evidence Storage
STORAGE_PROVIDER=database
UPLOAD_MAX_FILE_SIZE=52428800

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_BUCKET=assessors-studio-evidence
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false

# Event System
APP_URL=http://localhost:5173

# Encryption at Rest
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MASTER_ENCRYPTION_KEY=
# REQUIRE_ENCRYPTION=false

# Webhook Channel
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=5
WEBHOOK_DELIVERY_RETENTION_DAYS=30

# Email Channel (SMTP)
SMTP_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Chat Channels
SLACK_ENABLED=false
TEAMS_ENABLED=false
MATTERMOST_ENABLED=false
# CHAT_TIMEOUT=10000
# CHAT_DELIVERY_RETENTION_DAYS=30

# Prometheus Metrics
METRICS_ENABLED=false
# METRICS_TOKEN=
# METRICS_PREFIX=cdxa_
# METRICS_DOMAIN_REFRESH_INTERVAL=60
