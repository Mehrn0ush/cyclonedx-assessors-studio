# Database
DATABASE_PROVIDER=pglite
DATABASE_URL=postgresql://localhost:5432/assessors_studio
PGLITE_DATA_DIR=./data/pglite

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-secret-here-at-least-32-chars
JWT_EXPIRY=24h

# Server
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# Evidence Storage (spec 002)
STORAGE_PROVIDER=database
UPLOAD_MAX_FILE_SIZE=52428800

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_BUCKET=assessors-studio-evidence
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
